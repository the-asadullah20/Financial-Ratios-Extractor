# --- OCR backend selection ---
# "gemini" (recommended, fast & multimodal): uses Gemini 2.5 Flash Vision OCR
# "vllm": OpenAI-compatible vLLM server (e.g. Modal)
# "hf": Hugging Face Inference API
OCR_BACKEND=gemini

# Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OCR / processing behaviour
OCR_DPI=200
MAX_PAGES=35

# Storage directories
OUTPUT_DIR=output
UPLOAD_DIR=uploads_tmp
RAW_MARKDOWN_DIR=raw_markdown
QDRANT_STORAGE_PATH=qdrant_db

# --- Qdrant Cloud Cluster (Optional: leave blank for local persistent storage) ---
QDRANT_URL=https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key

# --- Cloud Bucket Storage (AWS S3 / Cloudflare R2 / MinIO / GCS) ---
S3_BUCKET_NAME=your_s3_or_r2_bucket_name
AWS_ACCESS_KEY_ID=your_aws_or_r2_access_key
AWS_SECRET_ACCESS_KEY=your_aws_or_r2_secret_key
AWS_REGION=us-east-1
S3_ENDPOINT_URL=  # Optional: e.g. https://storage.googleapis.com for GCS

# --- RabbitMQ Task Queue Settings ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=pdf_tasks
